		"commit": "cz",
		"prepare": "husky install",
		"fix-husky": "chmod +x .husky/pre-commit && chmod +x .husky/pre-push",
		"local-sonar": "sonar-scanner -Dsonar.projectKey=carlchanme_reactTutorialApp -Dsonar.sources=app -Dsonar.host.url=http://localhost:9000 -Dsonar.login=sqp_4bc8002092549c99525c716a736a2cd98e855eca -Dsonar.exclusions=**/*story.js -Dsonar.login=admin -Dsonar.password=Password1",
