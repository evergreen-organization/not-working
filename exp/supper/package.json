		"release-android-uat": "./release/release-android-uat.sh",
		"test-script": "./release/release-android-sit.sh",
		"detox-build-release:ios": "detox build --configuration ios.sim.release",
		"detox-build-debug:ios": "detox build --configuration ios.sim.debug",
		"detox-build-release:android": "detox build --configuration android.emu.release",
		"detox-build-release:debug": "detox build --configuration android.emu.debug",
		"detox-test-debug:ios": "detox test --configuration ios.sim.debug",
		"detox-test-release:ios": "detox test --configuration ios.sim.release",
		"detox-test-release:android": "detox test --configuration android.emu.release",
		"detox-test-debug:android": "detox test --configuration android.emu.debug",
		"release-builder": "node ./helper/index.mjs",
		"clean:ios": "rm -rf ios/Pods ios/Podfile.lock ios/build && cd ios && pod deintegrate && pod install && cd ..",
		"clean:android": "rm -rf android/build android/app/build && cd android && ./gradlew clean && cd ..",
		"clean:common": "rm -rf node_modules && npm cache clean --force && rm -rf yarn.lock package-lock.json && npm install",
		"clean:all": "npm run clean:common && npm run clean:ios && npm run clean:android"
